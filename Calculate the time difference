#include <stdio.h>

int main()
{
    int hour1,minute1;
    int hour2,minute2;
    
    printf("input hour and minute\n");
    
    scanf("%d %d",&hour1,&minute1);
    
    printf("Enter new input hour and minute\n");
    
    scanf("%d %d",&hour2,&minute2);
    
    int total=abs((hour1*60 + minute1)-(hour2*60 + minute2));
    
	printf("%d minute,%f hour \n",total,(double)total/60);

return 0;
}
